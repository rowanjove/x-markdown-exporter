{
  "manifest_version": 3,
  "name": "X Markdown Exporter",
  "version": "1.4.1",
  "description": "Export X (Twitter) posts and notes to Markdown with a draggable floating panel and link card support.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://pbs.twimg.com/*",
    "https://abs.twimg.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "jszip.min.js",
        "content-core.js",
        "content-export.js",
        "content-ui.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "X Markdown Exporter",
    "default_popup": "popup.html"
  }
}
